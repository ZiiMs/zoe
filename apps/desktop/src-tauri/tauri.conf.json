{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zoe",
  "version": "0.1.0",
  "identifier": "com.zoe.overlay",
  "build": {
    "beforeDevCommand": "bun run dev:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zoe Overlay",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
